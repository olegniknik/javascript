{
  "info": {
    "name": "Booking API",
    "description": "Коллекция для Booking Scaffold API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Clinics",
      "item": [
        {
          "name": "Create clinic",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Clinic\",\n  \"address\": \"Street 1\",\n  \"phone\": \"+79991234567\",\n  \"description\": \"Description\"\n}"
            },
            "url": "{{baseUrl}}/api/clinics",
            "description": "Создать клинику (ownerId = текущий пользователь)."
          }
        },
        {
          "name": "List clinics",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/clinics",
            "description": "Список клиник."
          }
        }
      ]
    },
    {
      "name": "Packages",
      "item": [
        {
          "name": "Create package",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Consultation\",\n  \"clinicId\": \"<clinic_id>\",\n  \"price_cents\": 5000,\n  \"duration_minutes\": 60\n}"
            },
            "url": "{{baseUrl}}/api/packages",
            "description": "Создать пакет услуги. clinicId из GET /clinics."
          }
        },
        {
          "name": "List packages",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/packages",
            "description": "Список пакетов (только active)."
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@local.test\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Логин email/password. В ответе access_token — подставить в переменную token для остальных запросов."
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create booking",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"packageId\": \"<package_id>\",\n  \"start_at\": \"2024-06-01T10:00:00.000Z\"\n}"
            },
            "url": "{{baseUrl}}/api/bookings",
            "description": "Создание брони. packageId из GET /packages, start_at — ISO 8601."
          }
        },
        {
          "name": "List bookings (cursor pagination)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/bookings?limit=5&cursor=",
              "host": ["{{baseUrl}}"],
              "path": ["bookings"],
              "query": [
                { "key": "limit", "value": "5" },
                { "key": "cursor", "value": "", "description": "nextCursor из предыдущего ответа" }
              ]
            },
            "description": "Список бронирований с cursor-pagination. nextCursor — для следующей страницы."
          }
        },
        {
          "name": "Create checkout session",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": \"<booking_id>\",\n  \"successUrl\": \"http://localhost:3000/booking/success\",\n  \"cancelUrl\": \"http://localhost:3000/booking/cancel\"\n}"
            },
            "url": "{{baseUrl}}/api/bookings/checkout",
            "description": "Получить URL Stripe Checkout для оплаты брони."
          }
        }
      ]
    },
    {
      "name": "Files",
      "item": [
        {
          "name": "Get presigned upload URL",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"filename\": \"document.pdf\",\n  \"size\": 1024,\n  \"mimeType\": \"application/pdf\"\n}"
            },
            "url": "{{baseUrl}}/api/files/presigned-url",
            "description": "Получить presigned URL для загрузки файла в S3/MinIO. Загрузка: PUT по uploadUrl с телом файла."
          }
        }
      ]
    },
    {
      "name": "Webhooks",
      "item": [
        {
          "name": "Stripe webhook (example payload)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "stripe-signature", "value": "<from Stripe>" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"checkout.session.completed\",\n  \"data\": { \"object\": { \"id\": \"cs_test_...\" } }\n}"
            },
            "url": "{{baseUrl}}/api/webhooks/stripe",
            "description": "Пример тела. В реальности вызывается Stripe с подписью. Локально — Stripe CLI forward."
          }
        }
      ]
    }
  ]
}
