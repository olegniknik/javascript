# ===========================================
# Booking Scaffold — переменные окружения
# Скопируйте в .env и подставьте значения
# ===========================================

# --- База данных ---
# PostgreSQL connection string (для docker: postgresql://postgres:postgres@localhost:5432/booking)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/booking"

# --- Redis (опционально для кэша/сессий) ---
REDIS_URL="redis://localhost:6379"

# --- Приложение ---
PORT=3000
# Базовый URL приложения (для Stripe success/cancel redirect)
APP_URL="http://localhost:3000"

# --- JWT ---
JWT_SECRET="your-super-secret-key-min-32-chars"
JWT_EXPIRES_IN="1h"

# --- Cursor pagination: секрет для подписи курсоров (HMAC). Обязателен для списков с пагинацией ---
CURSOR_SECRET="cursor-signing-secret-change-me"

# --- AWS S3 / MinIO ---
# Для MinIO: S3_ENDPOINT=http://localhost:9000 (или http://minio:9000 внутри docker)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET="uploads"
S3_REGION="us-east-1"
# Оставьте пустым для AWS; для MinIO: http://localhost:9000
S3_ENDPOINT=""

# --- Stripe (test keys для разработки) ---
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
# Webhook signing secret: Stripe CLI или Dashboard → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- Почта (уведомления о заявках с сайта) ---
# Если не заданы — заявки только пишутся в БД, письма не отправляются
SMTP_HOST="smtp.yandex.ru"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="noreply@mydomain.ru"
SMTP_PASSWORD=""
MAIL_FROM="noreply@mydomain.ru"
LEADS_EMAIL="manager@mydomain.ru"
