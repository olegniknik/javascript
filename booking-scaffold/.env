# ===========================================
# Booking Scaffold — переменные окружения
# Скопируйте в .env и подставьте значения
# ===========================================

# --- База данных ---
# Neon PostgreSQL (pooler)
DATABASE_URL="postgresql://neondb_owner:npg_7CPlKyErJHF2@ep-sweet-sunset-ajilyo7h-pooler.c-3.us-east-2.aws.neon.tech/neondb?sslmode=require"
# Direct connection (для миграций) — тот же Neon, без pooler:
DIRECT_URL="postgresql://neondb_owner:npg_7CPlKyErJHF2@ep-sweet-sunset-ajilyo7h.c-3.us-east-2.aws.neon.tech/neondb?sslmode=require"

# --- Redis (опционально для кэша/сессий) ---
REDIS_URL="redis://localhost:6379"

# --- Приложение ---
PORT=3000
# Базовый URL приложения (для Stripe success/cancel redirect)
APP_URL="http://localhost:3000"

# --- JWT ---
JWT_SECRET="your-super-secret-key-min-32-chars"
JWT_EXPIRES_IN="1h"

# --- Cursor pagination: секрет для подписи курсоров (HMAC). Обязателен для списков с пагинацией ---
CURSOR_SECRET="cursor-signing-secret-change-me"

# --- AWS S3 / MinIO ---
# Для MinIO: S3_ENDPOINT=http://localhost:9000 (или http://minio:9000 внутри docker)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET="uploads"
S3_REGION="us-east-1"
# Оставьте пустым для AWS; для MinIO: http://localhost:9000
S3_ENDPOINT=""

# --- Stripe (test keys для разработки) ---
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
# Webhook signing secret: Stripe CLI или Dashboard → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- Почта (уведомления о заявках с сайта через Resend HTTP API) ---
# Получите API-ключ на https://resend.com/api-keys
RESEND_API_KEY=""
# Адрес отправителя (используйте onboarding@resend.dev для теста, или свой домен после верификации)
MAIL_FROM="onboarding@resend.dev"
# Куда приходят уведомления о заявках
LEADS_EMAIL="nikiforov-kslksl@yandex.ru"
