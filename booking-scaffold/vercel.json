{
  "version": 2,
  "buildCommand": "npm run build",
  "functions": {
    "api/index.js": {
      "includeFiles": "dist/**"
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "api/index.js" },
    { "src": "/admin(/?)(.*)", "dest": "/admin/index.html" },
    { "src": "/((?!api/).*)", "dest": "/index.html" }
  ]
}
