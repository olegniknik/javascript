{
  "version": 2,
  "buildCommand": "npm run build",
  "functions": {
    "api/index.js": {
      "includeFiles": "dist/**"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.js" },
    { "src": "/admin/style.css", "dest": "public/admin/style.css" },
    { "src": "/admin/app.js", "dest": "public/admin/app.js" },
    { "src": "/admin(.*)", "dest": "public/admin/index.html" },
    { "src": "/styles.css", "dest": "public/styles.css" },
    { "src": "/script.js(.*)", "dest": "public/script.js" },
    { "src": "/((?!api/).*)", "dest": "public/index.html" }
  ]
}
